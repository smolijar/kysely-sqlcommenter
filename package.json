{
  "name": "kysely-sqlcommenter",
  "version": "0.2.0",
  "description": "SqlCommenter plugin and helpers for Kysely",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "author": "Jaroslav Šmolík <smolijar@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smolijar/kysely-sqlcommenter.git"
  },
  "homepage": "https://github.com/smolijar/kysely-sqlcommenter#readme",
  "bugs": {
    "url": "https://github.com/smolijar/kysely-sqlcommenter/issues"
  },
  "sideEffects": false,
  "keywords": [
    "kysely",
    "sqlcommenter",
    "sql"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/kysely-sqlcommenter.umd.cjs",
  "module": "./dist/kysely-sqlcommenter.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/kysely-sqlcommenter.js",
      "require": "./dist/kysely-sqlcommenter.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.build.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:integration": "./integration-test-builder/test.sh",
    "audit": "pnpm audit --audit-level high",
    "prepublishOnly": "pnpm test && pnpm run test:integration"
  },
  "peerDependencies": {
    "kysely": ">=0.28.17 <0.30.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "kysely": "^0.29.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.9"
  }
}
